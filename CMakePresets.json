{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (GCC)",
      "description": "Build with GCC (default)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug",
      "description": "Debug build with GCC",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-gcc",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "coverage",
      "displayName": "GCC Coverage",
      "description": "Debug build with GCC and coverage instrumentation",
      "inherits": "gcc-debug",
      "binaryDir": "${sourceDir}/build-coverage",
      "cacheVariables": {
        "BUILD_EXAMPLES": "OFF",
        "BUILD_TESTS": "ON",
        "CMAKE_C_FLAGS": "--coverage -O0 -g",
        "CMAKE_CXX_FLAGS": "--coverage -O0 -g",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage",
        "CMAKE_SHARED_LINKER_FLAGS": "--coverage"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release",
      "description": "Optimized release build with GCC",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-gcc-release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_OPTIMIZED": "ON"
      }
    },
    {
      "name": "clang-debug",
      "displayName": "Clang Debug",
      "description": "Debug build with Clang using GCC's libstdc++",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-clang",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_FLAGS_INIT": "-I/usr/include/c++/13 -I/usr/include/x86_64-linux-gnu/c++/13 -nostdlib++",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "/usr/lib/x86_64-linux-gnu/libstdc++.so.6"
      }
    },
    {
      "name": "clang-release",
      "displayName": "Clang Release",
      "description": "Optimized release build with Clang",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-clang-release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_OPTIMIZED": "ON",
        "CMAKE_CXX_FLAGS_INIT": "-I/usr/include/c++/13 -I/usr/include/x86_64-linux-gnu/c++/13 -nostdlib++",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "/usr/lib/x86_64-linux-gnu/libstdc++.so.6"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release"
    },
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug"
    },
    {
      "name": "clang-release",
      "configurePreset": "clang-release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {"outputOnFailure": true},
      "execution": {"jobs": 2}
    },
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug",
      "output": {"outputOnFailure": true}
    }
  ]
}
